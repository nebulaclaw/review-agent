# Copy this file to `.env` and fill in secrets. `.env` is gitignored—never commit real keys in tracked files.

# You can set keys for multiple vendors; after changing `llm.provider` in config.yaml, if `api_key` is empty
# the matching env var is used: openai→OPENAI_API_KEY, glm/zhipu→ZHIPUAI_API_KEY, kimi→MOONSHOT_API_KEY,
# qwen→DASHSCOPE_API_KEY, minimax→MINIMAX_API_KEY.
# If the vendor-specific variable is unset, the code falls back to LLM_API_KEY (shared key or custom gateway).
LLM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZHIPUAI_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Local Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# TUI → review API base URL; default is local server
# REVIEW_AGENT_API_BASE_URL=http://127.0.0.1:18080

# Optional: when YAML uses ${VAR}, define the same name in the environment

# Audit / queue SQLite paths (optional overrides)
# REVIEW_DB_PATH=data/review.db
# QUEUE_DB_PATH=data/queue.db

LOG_LEVEL=INFO
